<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>GPS Tracker Mobile PWA V7</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">
<link rel="manifest" href="manifest.webmanifest">
<meta name="theme-color" content="#0f5fad">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="GPS Tracker">
<link rel="apple-touch-icon" href="icons/icon-192.png">

<style>
*{box-sizing:border-box}
body{margin:0;font-family:Arial,"Segoe UI",sans-serif;background:#eef2f7;color:#1f2937}
header{background:#0f5fad;color:#fff;padding:16px;text-align:center;font-size:22px;font-weight:bold}
.dashboard{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;padding:12px}
.card{background:#fff;border-radius:12px;padding:12px;box-shadow:0 2px 8px rgba(0,0,0,.15)}
.card-title{color:#64748b;font-size:14px}.card-value{font-size:19px;font-weight:bold}
.main{display:grid;grid-template-columns:360px 1fr;height:calc(100vh - 150px)}
.side{background:#fff;padding:16px;box-shadow:2px 0 8px rgba(0,0,0,.15);overflow:auto}
.row{border-bottom:1px solid #ddd;padding:8px 0}.label{display:block;color:#64748b;font-size:13px}.value{font-weight:bold;word-break:break-all}
.online{color:#16a34a}.offline{color:#dc2626}.waiting{color:#f59e0b}
#map{width:100%;height:100%}
button,a.btn{display:block;margin-top:10px;padding:11px;border-radius:8px;border:0;background:#1976d2;color:white;text-align:center;text-decoration:none;font-weight:bold;cursor:pointer}
.btn-red{background:#dc2626}.btn-gray{background:#475569}.btn-green{background:#16a34a}.btn-orange{background:#f59e0b}
.note{color:#64748b;font-size:13px;line-height:1.5}
.vehicle-icon{font-size:36px;filter:drop-shadow(0 3px 4px rgba(0,0,0,.5));transform-origin:center center;transition:transform .25s linear}
.history-panel{margin-top:14px;border:1px solid #d1d5db;border-radius:12px;padding:12px;background:#f8fafc}
.history-panel h3{margin:0 0 8px 0}.mini{font-size:12px;color:#64748b;line-height:1.45}.btn-purple{background:#7c3aed}.btn-teal{background:#0d9488}
.history-table{width:100%;border-collapse:collapse;margin-top:10px;font-size:12px;background:white;border-radius:8px;overflow:hidden}
.history-table th,.history-table td{border-bottom:1px solid #e5e7eb;padding:7px;text-align:left;vertical-align:top}
.history-table th{background:#e0f2fe;color:#075985}.place-text{max-width:220px;line-height:1.35}.btn-blue{background:#2563eb}
@media(max-width:900px){.dashboard{grid-template-columns:repeat(2,1fr)}.main{grid-template-columns:1fr;height:auto}#map{height:65vh}.side{order:2}}

/* V7 Mobile PWA polish */
:root{--safe-bottom:env(safe-area-inset-bottom,0px)}
.install-help{font-size:12px;color:#64748b;margin-top:6px;line-height:1.35}
@media(max-width:900px){
  body{background:#f8fafc;}
  header{position:sticky;top:0;z-index:1000;font-size:18px;padding:13px 10px;padding-top:calc(13px + env(safe-area-inset-top,0px));}
  .dashboard{position:sticky;top:50px;z-index:900;grid-template-columns:repeat(2,1fr);gap:8px;padding:8px;background:#f8fafc;}
  .dashboard .card{padding:10px;border-radius:14px;}
  .card-title{font-size:12px}.card-value{font-size:18px}
  .main{display:flex;flex-direction:column;height:auto;}
  #map{height:58vh;min-height:390px;order:1;}
  .side{order:2;padding:12px 12px calc(20px + var(--safe-bottom));box-shadow:none;}
  .side h2{font-size:18px;margin:6px 0 10px;}
  .row{padding:7px 0;}
  button,a.btn{font-size:15px;padding:13px;border-radius:12px;margin-top:8px;}
  .history-panel{padding:10px;margin-top:12px;border-radius:14px;}
  .history-table{font-size:11px;}
  .history-table th,.history-table td{padding:6px 4px;}
  .place-text{max-width:150px;}
}
@media(max-width:430px){
  .dashboard{grid-template-columns:repeat(2,1fr);}
  .dashboard .card:nth-child(3){grid-column:span 2;text-align:center;background:#e0f2fe;}
  #map{height:55vh;min-height:360px;}
}
</style>
</head>
<body>
<header>🚚 GPS Tracker Mobile PWA V7</header>

<div class="dashboard">
  <div class="card"><div class="card-title">สถานะ</div><div id="statusTop" class="card-value waiting">รอข้อมูล...</div></div>
  <div class="card"><div class="card-title">ดาวเทียม</div><div class="card-value"><span id="satTop">-</span> ดวง</div></div>
  <div class="card"><div class="card-title">ความเร็วคำนวณ</div><div class="card-value"><span id="speedTop">-</span> km/h</div></div>
  <div class="card"><div class="card-title">ระยะทางรวม</div><div class="card-value"><span id="totalTop">0</span> m</div></div>
  <div class="card"><div class="card-title">ความเร็วสูงสุด</div><div class="card-value"><span id="maxSpeedTop">0.00</span> km/h</div></div>
</div>

<div class="main">
  <div class="side">
    <h2>ข้อมูลรถขนส่ง</h2>
    <div class="row"><span class="label">สถานะ</span><span id="status" class="value waiting">รอข้อมูล...</span></div>
    <div class="row"><span class="label">Latitude</span><span id="lat" class="value">-</span></div>
    <div class="row"><span class="label">Longitude</span><span id="lon" class="value">-</span></div>
    <div class="row"><span class="label">Satellites</span><span id="sat" class="value">-</span></div>
    <div class="row"><span class="label">Speed แสดงผล</span><span id="speed" class="value">-</span></div>
    <div class="row"><span class="label">Raw Speed จาก GPS</span><span id="rawSpeed" class="value">-</span></div>
    <div class="row"><span class="label">Speed จาก ESP32</span><span id="espSpeed" class="value">-</span></div>
    <div class="row"><span class="label">Distance drift</span><span id="drift" class="value">-</span></div>
    <div class="row"><span class="label">ระยะทางรวม</span><span id="totalDistance" class="value">0 m</span></div>
    <div class="row"><span class="label">ความเร็วสูงสุด</span><span id="maxSpeed" class="value">0.00 km/h</span></div>
    <div class="row"><span class="label">เวลาที่ระบบออนไลน์</span><span id="onlineTime" class="value">-</span></div>
    <div class="row"><span class="label">Sequence</span><span id="seq" class="value">-</span></div>
    <div class="row"><span class="label">อัปเดตล่าสุด</span><span id="time" class="value">-</span></div>
    <div class="row"><span class="label">Google Maps</span><span id="gmapsText" class="value">-</span></div>


    <button class="btn-purple" onclick="installApp()" id="installBtn">📱 ติดตั้งบนหน้าจอโทรศัพท์</button>
    <div class="install-help" id="installHelp">Android: กดปุ่มติดตั้ง / iPhone: กด Share → Add to Home Screen</div>
    <button class="btn-green" onclick="followCar()">📍 ติดตามรถ</button>
    <button class="btn-orange" onclick="toggleAutoFollow()" id="autoFollowBtn">🧭 Auto Follow: ON</button>
    <a id="googleMapsBtn" class="btn" target="_blank">🗺 เปิด Google Maps</a>
    <button class="btn-gray" onclick="toggleRoute()">🛣 เปิด/ปิดเส้นทาง</button>
    <button class="btn-red" onclick="clearRoute()">🧹 ล้างเส้นทางสด</button>

    <div class="history-panel">
      <h3>📜 ประวัติการวิ่ง</h3>
      <button class="btn-purple" onclick="loadHistoryRoute()">โหลดประวัติจาก Firebase</button>
      <button class="btn-teal" onclick="showLiveRoute()">กลับไปดูเส้นทางสด</button>
      <button class="btn-gray" onclick="exportHistoryCSV()">⬇ Export CSV</button>
      <button class="btn-blue" onclick="replayHistoryRoute()">▶ Replay เส้นทางย้อนหลัง</button>
      <button class="btn-red" onclick="stopReplay()">⏹ หยุด Replay</button>
      <button class="btn-red" onclick="clearHistoryView()">ล้างเส้นประวัติบนแผนที่</button>
      <div class="row"><span class="label">จำนวนจุดประวัติ</span><span id="historyCount" class="value">0 จุด</span></div>
      <div class="row"><span class="label">ระยะทางประวัติ</span><span id="historyDistance" class="value">0 m</span></div>
      <div class="row"><span class="label">ความเร็วสูงสุดในประวัติ</span><span id="historyMaxSpeed" class="value">0.00 km/h</span></div>
      <div class="row"><span class="label">สถานที่เริ่มต้น</span><span id="startPlace" class="value">-</span></div>
      <div class="row"><span class="label">สถานที่สุดท้าย</span><span id="endPlace" class="value">-</span></div>
      <table class="history-table">
        <thead><tr><th>จุด</th><th>เวลา/ลำดับ</th><th>สถานที่</th><th>Speed</th></tr></thead>
        <tbody id="historyTableBody"><tr><td colspan="4">ยังไม่ได้โหลดประวัติ</td></tr></tbody>
      </table>
      <div class="mini">หมายเหตุ: ชื่อสถานที่ใช้ OpenStreetMap Nominatim ฟรี ไม่ต้องสมัคร API Key แต่ต้องมีอินเทอร์เน็ต และควรใช้เพื่อสาธิต/โครงงาน ไม่ควรเรียกถี่เกินไป</div>
    </div>

    <p class="note">
      V7 Mobile PWA: ติดตั้งเป็นแอปบนมือถือ + Realtime + Smart Route + ประวัติย้อนหลัง + ชื่อสถานที่ + Replay + Export CSV
    </p>
  </div>

  <div id="map"></div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
const firebaseURL = "https://gps-tracker-a20ca-default-rtdb.asia-southeast1.firebasedatabase.app/vehicle/location.json";
const firebaseHistoryURL = "https://gps-tracker-a20ca-default-rtdb.asia-southeast1.firebasedatabase.app/vehicle/history.json";

const OFFLINE_LIMIT_MS = 15000;
// V4.5 Smart Route
// หลักการ: รถวิ่งจริงใช้ Raw GPS Speed เป็นหลัก / รถจอดให้แสดง 0 และไม่ลากเส้นหลอก
const GPS_MOVE_THRESHOLD_M = 2.5;      // รถวิ่งจริง เก็บจุดถี่ขึ้นกว่า V4.3/V4.4
const STOP_DRIFT_THRESHOLD_M = 10;     // รถจอด ถ้าขยับต่ำกว่านี้ถือว่า GPS แกว่ง
const FORCE_MOVE_DISTANCE_M = 8;       // ขยับไกลพอให้ยอมรับเร็วขึ้น
const ROUTE_POINT_MIN_M = 2;           // จุดเส้นทางถี่ขึ้น ช่วยให้เส้นโค้งตามถนนมากขึ้น
const MIN_REAL_SPEED_KMH = 2;
const MIN_RAW_MOVING_SPEED_KMH = 5;    // ต่ำกว่านี้ยังไม่ถือว่าวิ่งจริง
const MAX_REASONABLE_SPEED_KMH = 180;
const SMOOTH_STEPS = 6;
const SMOOTH_DELAY_MS = 18;

let currentLat = 13.7563;
let currentLon = 100.5018;
let isFirstLoad = true;
let autoFollow = true;

let routePoints = [];
let routeLine = null;
let routeVisible = true;

let lastSignature = null;
let lastFreshTime = 0;
let firstOnlineTime = 0;

let lastAcceptedLat = null;
let lastAcceptedLon = null;
let lastAcceptedTime = 0;
let lastHeading = 0;
let displaySpeed = 0;
let maxSpeed = 0;
let totalDistance = 0;
let smoothTimer = null;

let historyPoints = [];
let historyLine = null;
let historyStartMarker = null;
let historyEndMarker = null;
let viewingHistory = false;
let placeCache = {};
let replayTimer = null;
let replayMarker = null;

const map = L.map("map").setView([currentLat, currentLon], 13);
L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
  attribution: "© OpenStreetMap contributors"
}).addTo(map);

const truckIcon = L.divIcon({
  html: '<div id="truckIcon" class="vehicle-icon">🚚</div>',
  className: "",
  iconSize: [42,42],
  iconAnchor: [21,21]
});

const marker = L.marker([currentLat,currentLon], {icon: truckIcon}).addTo(map)
  .bindPopup("รอตำแหน่งรถ...");

function setText(id, value){ document.getElementById(id).textContent = value; }

function setStatus(mode){
  let text = "รอข้อมูล...";
  let cls = "waiting";
  if(mode === "online"){ text = "online"; cls = "online"; }
  if(mode === "offline"){ text = "offline"; cls = "offline"; }
  setText("status", text);
  setText("statusTop", text);
  document.getElementById("status").className = "value " + cls;
  document.getElementById("statusTop").className = "card-value " + cls;
}

function followCar(){
  map.setView([currentLat, currentLon], 17);
  marker.openPopup();
}

function toggleAutoFollow(){
  autoFollow = !autoFollow;
  setText("autoFollowBtn", autoFollow ? "🧭 Auto Follow: ON" : "🧭 Auto Follow: OFF");
}

function updateRoute(lat, lon){
  const point = [lat, lon];
  if(routePoints.length === 0){
    routePoints.push(point);
  }else{
    const last = routePoints[routePoints.length - 1];
    // V4.5: เก็บจุดถี่ขึ้น เพื่อให้เส้นไม่ลากตัดโค้ง/สะพานมากเกินไป
    if(map.distance(last, point) >= ROUTE_POINT_MIN_M){
      routePoints.push(point);
    }
  }
  if(routePoints.length > 1200) routePoints.shift();
  if(routeLine) routeLine.setLatLngs(routePoints);
  else routeLine = L.polyline(routePoints, {weight:5, opacity:.85, smoothFactor:0.3}).addTo(map);
  if(routeLine && !routeVisible) map.removeLayer(routeLine);
}

function clearRoute(){
  routePoints = [];
  totalDistance = 0;
  maxSpeed = 0;
  setText("totalDistance", "0 m");
  setText("totalTop", "0");
  setText("maxSpeed", "0.00 km/h");
  setText("maxSpeedTop", "0.00");
  if(routeLine){ map.removeLayer(routeLine); routeLine = null; }
}

function toggleRoute(){
  routeVisible = !routeVisible;
  if(routeLine){
    if(routeVisible) routeLine.addTo(map);
    else map.removeLayer(routeLine);
  }
}

function bearingDeg(lat1, lon1, lat2, lon2){
  const toRad = d => d * Math.PI / 180;
  const toDeg = r => r * 180 / Math.PI;
  const y = Math.sin(toRad(lon2-lon1)) * Math.cos(toRad(lat2));
  const x = Math.cos(toRad(lat1))*Math.sin(toRad(lat2)) -
            Math.sin(toRad(lat1))*Math.cos(toRad(lat2))*Math.cos(toRad(lon2-lon1));
  return (toDeg(Math.atan2(y,x)) + 360) % 360;
}

function rotateTruck(deg){
  const el = document.getElementById("truckIcon");
  if(el) el.style.transform = `rotate(${deg}deg)`;
}

function smoothMoveMarker(fromLat, fromLon, toLat, toLon){
  if(smoothTimer) clearInterval(smoothTimer);
  let step = 0;
  smoothTimer = setInterval(() => {
    step++;
    const t = step / SMOOTH_STEPS;
    const lat = fromLat + (toLat - fromLat) * t;
    const lon = fromLon + (toLon - fromLon) * t;
    marker.setLatLng([lat, lon]);
    if(step >= SMOOTH_STEPS){
      clearInterval(smoothTimer);
      smoothTimer = null;
      marker.setLatLng([toLat, toLon]);
    }
  }, SMOOTH_DELAY_MS);
}

function formatDistance(m){
  if(m >= 1000) return (m/1000).toFixed(2) + " km";
  return m.toFixed(0) + " m";
}

function formatDuration(ms){
  if(!ms || ms < 0) return "-";
  const s = Math.floor(ms/1000);
  const h = Math.floor(s/3600);
  const m = Math.floor((s%3600)/60);
  const sec = s%60;
  return `${h} ชม. ${m} นาที ${sec} วิ`;
}

function calculateRealSpeed(distanceM, dtMs){
  if(dtMs <= 0) return 0;
  const kmh = (distanceM / (dtMs / 1000)) * 3.6;
  if(!isFinite(kmh) || kmh < MIN_REAL_SPEED_KMH) return 0;
  if(kmh > MAX_REASONABLE_SPEED_KMH) return 0;
  return kmh;
}

function dynamicMoveThreshold(speedKmh, distanceM){
  // V4.5: รถวิ่งเร็วให้เก็บจุดถี่ / รถจอดให้กัน drift หนักขึ้น
  if(speedKmh >= 50) return 2;
  if(speedKmh >= 20) return 2.5;
  if(speedKmh >= 8) return 3;
  if(speedKmh >= MIN_RAW_MOVING_SPEED_KMH) return 4;
  if(distanceM >= FORCE_MOVE_DISTANCE_M) return FORCE_MOVE_DISTANCE_M;
  return STOP_DRIFT_THRESHOLD_M;
}

function chooseDisplaySpeed(rawSpeed, espSpeed, realSpeed, isMoving){
  // ตอนจอด rawSpeed อาจเพี้ยนได้ เช่น 16 km/h ทั้งที่รถนิ่ง จึงต้องเช็ก isMoving ก่อน
  if(!isMoving) return 0;

  // ตอนรถวิ่งจริง ค่า Raw GPS Speed มักใกล้เคียงหน้าปัดรถกว่า speed ที่คำนวณจากระยะ/เวลา
  if(rawSpeed >= MIN_RAW_MOVING_SPEED_KMH && rawSpeed <= MAX_REASONABLE_SPEED_KMH) return rawSpeed;
  if(espSpeed >= MIN_REAL_SPEED_KMH && espSpeed <= MAX_REASONABLE_SPEED_KMH) return espSpeed;
  if(realSpeed >= MIN_REAL_SPEED_KMH && realSpeed <= MAX_REASONABLE_SPEED_KMH) return realSpeed;
  return 0;
}


function cleanupHistoryMarkers(){
  if(historyLine){ map.removeLayer(historyLine); historyLine = null; }
  if(historyStartMarker){ map.removeLayer(historyStartMarker); historyStartMarker = null; }
  if(historyEndMarker){ map.removeLayer(historyEndMarker); historyEndMarker = null; }
}

function clearHistoryView(){
  stopReplay();
  cleanupHistoryMarkers();
  viewingHistory = false;
  historyPoints = [];
  setText("historyCount", "0 จุด");
  setText("historyDistance", "0 m");
  setText("historyMaxSpeed", "0.00 km/h");
  setText("startPlace", "-");
  setText("endPlace", "-");
  document.getElementById("historyTableBody").innerHTML = '<tr><td colspan="4">ยังไม่ได้โหลดประวัติ</td></tr>';
}

function showLiveRoute(){
  cleanupHistoryMarkers();
  viewingHistory = false;
  if(routeLine && routeVisible) routeLine.addTo(map);
  map.setView([currentLat, currentLon], 17);
}

function normalizeHistoryObject(obj){
  if(!obj) return [];
  return Object.keys(obj).map(k => {
    const v = obj[k] || {};
    return {
      key: k,
      lat: Number(v.latitude),
      lon: Number(v.longitude),
      speed: Math.abs(Number(v.rawSpeed ?? v.speed ?? 0)),
      sat: v.satellites ?? "-",
      sequence: Number(v.sequence ?? 0),
      deviceMillis: Number(v.deviceMillis ?? v.savedAt ?? 0)
    };
  }).filter(p => isFinite(p.lat) && isFinite(p.lon) && p.lat !== 0 && p.lon !== 0)
    .sort((a,b) => (a.sequence || a.deviceMillis) - (b.sequence || b.deviceMillis));
}


function sleep(ms){ return new Promise(resolve => setTimeout(resolve, ms)); }
function placeKey(lat, lon){ return lat.toFixed(4) + "," + lon.toFixed(4); }

async function reverseGeocode(lat, lon){
  const key = placeKey(lat, lon);
  if(placeCache[key]) return placeCache[key];
  try{
    const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lon}&zoom=18&accept-language=th`;
    const res = await fetch(url, {headers:{"Accept":"application/json"}});
    const data = await res.json();
    const addr = data.address || {};
    const parts = [
      data.name,
      addr.road,
      addr.suburb || addr.town || addr.village || addr.city_district,
      addr.city || addr.county || addr.state,
      addr.postcode
    ].filter(Boolean);
    const place = parts.length ? [...new Set(parts)].join(" ") : `${lat.toFixed(6)}, ${lon.toFixed(6)}`;
    placeCache[key] = place;
    return place;
  }catch(err){
    console.log("Reverse geocode error", err);
    return `${lat.toFixed(6)}, ${lon.toFixed(6)}`;
  }
}

function selectedHistorySamples(points){
  if(points.length <= 12) return points.map((p,i)=>({p, i, label:i===0?"เริ่ม":(i===points.length-1?"สิ้นสุด":"ผ่าน")}));
  const out = [];
  out.push({p:points[0], i:0, label:"เริ่ม"});
  const step = Math.max(1, Math.floor(points.length / 8));
  for(let i=step; i<points.length-1; i+=step){
    out.push({p:points[i], i, label:"ผ่าน"});
    if(out.length >= 10) break;
  }
  out.push({p:points[points.length-1], i:points.length-1, label:"สิ้นสุด"});
  return out;
}

async function renderHistoryPlaces(points){
  const tbody = document.getElementById("historyTableBody");
  const samples = selectedHistorySamples(points);
  tbody.innerHTML = samples.map((x,idx)=>`<tr id="histRow${idx}"><td>${x.label}</td><td>${x.p.sequence || x.i}</td><td class="place-text">กำลังค้นหาชื่อสถานที่...</td><td>${x.p.speed.toFixed(1)} km/h</td></tr>`).join("");
  if(points.length === 0) return;
  const start = await reverseGeocode(points[0].lat, points[0].lon);
  setText("startPlace", start);
  await sleep(1100);
  const end = await reverseGeocode(points[points.length-1].lat, points[points.length-1].lon);
  setText("endPlace", end);
  for(let idx=0; idx<samples.length; idx++){
    const x = samples[idx];
    const place = await reverseGeocode(x.p.lat, x.p.lon);
    const row = document.getElementById("histRow" + idx);
    if(row){
      row.cells[2].textContent = place;
      row.style.cursor = "pointer";
      row.onclick = () => {
        map.setView([x.p.lat, x.p.lon], 18);
        L.popup().setLatLng([x.p.lat, x.p.lon]).setContent(`<b>${x.label}</b><br>${place}<br>Speed: ${x.p.speed.toFixed(1)} km/h`).openOn(map);
      };
    }
    await sleep(1100);
  }
}

function stopReplay(){
  if(replayTimer){ clearInterval(replayTimer); replayTimer = null; }
  if(replayMarker){ map.removeLayer(replayMarker); replayMarker = null; }
}

function replayHistoryRoute(){
  if(!historyPoints || historyPoints.length < 2){ alert("กรุณาโหลดประวัติก่อน"); return; }
  stopReplay();
  let i = 0;
  replayMarker = L.marker([historyPoints[0].lat, historyPoints[0].lon], {icon: truckIcon}).addTo(map).bindPopup("Replay");
  map.setView([historyPoints[0].lat, historyPoints[0].lon], 17);
  replayTimer = setInterval(() => {
    i++;
    if(i >= historyPoints.length){ stopReplay(); return; }
    const p = historyPoints[i];
    replayMarker.setLatLng([p.lat, p.lon]);
    map.panTo([p.lat, p.lon], {animate:true, duration:.2});
  }, 250);
}

function renderHistory(points){
  cleanupHistoryMarkers();
  historyPoints = points;
  viewingHistory = true;

  if(routeLine) map.removeLayer(routeLine);

  if(points.length === 0){
    alert("ยังไม่มีข้อมูลประวัติใน Firebase");
    setText("historyCount", "0 จุด");
    return;
  }

  const latlngs = points.map(p => [p.lat, p.lon]);
  let distance = 0;
  let historyMax = 0;
  for(let i=1;i<latlngs.length;i++) distance += map.distance(latlngs[i-1], latlngs[i]);
  for(const p of points) if(p.speed > historyMax && p.speed <= MAX_REASONABLE_SPEED_KMH) historyMax = p.speed;

  historyLine = L.polyline(latlngs, {weight:6, opacity:.9, smoothFactor:0.2}).addTo(map);
  historyStartMarker = L.marker(latlngs[0]).addTo(map).bindPopup("✅ จุดเริ่มต้น");
  historyEndMarker = L.marker(latlngs[latlngs.length-1]).addTo(map).bindPopup("🏁 จุดล่าสุด/จุดสิ้นสุด");
  map.fitBounds(historyLine.getBounds(), {padding:[30,30]});

  setText("historyCount", points.length + " จุด");
  setText("historyDistance", formatDistance(distance));
  setText("historyMaxSpeed", historyMax.toFixed(2) + " km/h");
  renderHistoryPlaces(points);
}

async function loadHistoryRoute(){
  try{
    setText("historyCount", "กำลังโหลด...");
    const res = await fetch(firebaseHistoryURL + "?t=" + Date.now(), {cache:"no-store"});
    const obj = await res.json();
    const points = normalizeHistoryObject(obj);
    renderHistory(points);
  }catch(err){
    console.log(err);
    alert("โหลดประวัติไม่สำเร็จ ตรวจสอบอินเทอร์เน็ตหรือ Firebase");
    setText("historyCount", "โหลดไม่สำเร็จ");
  }
}

async function exportHistoryCSV(){
  if(!historyPoints || historyPoints.length === 0){
    alert("กรุณากดโหลดประวัติก่อน");
    return;
  }
  const rows = [["sequence","deviceMillis","latitude","longitude","place","speed_kmh","satellites"]];
  for(const p of historyPoints){
    const place = placeCache[placeKey(p.lat,p.lon)] || "";
    rows.push([p.sequence, p.deviceMillis, p.lat, p.lon, '"' + String(place).replaceAll('"','""') + '"', p.speed, p.sat]);
  }
  const csv = rows.map(r => r.join(",")).join("\n");
  const blob = new Blob([csv], {type:"text/csv;charset=utf-8"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "gps_history.csv";
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function processGPS(data){
  if(!data || data.latitude === undefined || data.longitude === undefined){
    setStatus("offline");
    return;
  }

  const now = Date.now();
  const lat = Number(data.latitude);
  const lon = Number(data.longitude);
  if(!isFinite(lat) || !isFinite(lon) || lat === 0 || lon === 0){
    setStatus("offline");
    return;
  }

  const sat = data.satellites ?? "-";
  const espSpeed = Math.abs(Number(data.speed ?? 0));
  const rawSpeed = Math.abs(Number(data.rawSpeed ?? espSpeed));
  const seq = data.sequence ?? "-";
  const deviceMillis = data.deviceMillis ?? "-";

  // V4.4: ถ้า Firebase ส่งข้อมูลใหม่มา ให้ถือว่าออนไลน์ทันที
  const signature = [
    lat.toFixed(7), lon.toFixed(7), sat, espSpeed.toFixed(2), rawSpeed.toFixed(2), seq, deviceMillis
  ].join("|");

  if(lastSignature === null || signature !== lastSignature){
    lastSignature = signature;
    lastFreshTime = now;
    if(!firstOnlineTime) firstOnlineTime = now;
    setStatus("online");
  }else{
    setStatus((now - lastFreshTime <= OFFLINE_LIMIT_MS) ? "online" : "offline");
  }

  const driftDistance = map.distance([currentLat,currentLon], [lat,lon]);
  let distanceFromAccepted = 0;
  let dtMs = 0;
  let realSpeed = 0;

  if(lastAcceptedLat !== null){
    distanceFromAccepted = map.distance([lastAcceptedLat,lastAcceptedLon], [lat,lon]);
    dtMs = now - lastAcceptedTime;
    realSpeed = calculateRealSpeed(distanceFromAccepted, dtMs);
  }

  const speedHint = Math.max(realSpeed, espSpeed, rawSpeed);
  const moveThreshold = dynamicMoveThreshold(speedHint, distanceFromAccepted);

  // V4.5: ยอมรับการเคลื่อนที่เร็วขึ้น แต่ยังกัน GPS drift ตอนจอด
  const movingBySpeed = rawSpeed >= MIN_RAW_MOVING_SPEED_KMH || espSpeed >= MIN_REAL_SPEED_KMH || realSpeed >= MIN_REAL_SPEED_KMH;
  const movingByDistance = distanceFromAccepted >= moveThreshold;
  const forceMove = distanceFromAccepted >= FORCE_MOVE_DISTANCE_M && rawSpeed >= MIN_REAL_SPEED_KMH;
  const shouldMove = isFirstLoad || ((movingByDistance && movingBySpeed) || forceMove);

  if(isFirstLoad){
    currentLat = lat;
    currentLon = lon;
    lastAcceptedLat = lat;
    lastAcceptedLon = lon;
    lastAcceptedTime = now;
    displaySpeed = 0;
    marker.setLatLng([lat,lon]);
    updateRoute(lat,lon);
  }else if(shouldMove){
    const oldLat = currentLat;
    const oldLon = currentLon;

    const selectedSpeed = chooseDisplaySpeed(rawSpeed, espSpeed, realSpeed, true);
    if(selectedSpeed > 0){
      // V4.5: ใช้ Raw GPS Speed ตอนวิ่งจริง และ smooth นิดเดียว ไม่กดค่าจนต่ำเกินจริง
      displaySpeed = (displaySpeed * 0.20) + (selectedSpeed * 0.80);
    }else{
      displaySpeed = 0;
    }
    if(displaySpeed < MIN_REAL_SPEED_KMH) displaySpeed = 0;
    if(displaySpeed > maxSpeed) maxSpeed = displaySpeed;

    if(distanceFromAccepted >= GPS_MOVE_THRESHOLD_M){
      totalDistance += distanceFromAccepted;
    }

    currentLat = lat;
    currentLon = lon;
    lastAcceptedLat = lat;
    lastAcceptedLon = lon;
    lastAcceptedTime = now;
    lastHeading = bearingDeg(oldLat, oldLon, lat, lon);
    rotateTruck(lastHeading);
    smoothMoveMarker(oldLat, oldLon, lat, lon);
    updateRoute(lat,lon);
    if(autoFollow && !viewingHistory) map.panTo([lat,lon], {animate:true, duration:.25});
  }else{
    displaySpeed = 0;
  }

  setText("lat", lat.toFixed(7));
  setText("lon", lon.toFixed(7));
  setText("sat", sat);
  setText("satTop", sat);
  setText("speed", displaySpeed.toFixed(2) + " km/h");
  setText("speedTop", displaySpeed.toFixed(2));
  setText("rawSpeed", rawSpeed.toFixed(2) + " km/h");
  setText("espSpeed", espSpeed.toFixed(2) + " km/h");
  setText("drift", driftDistance.toFixed(1) + " m");
  setText("totalDistance", formatDistance(totalDistance));
  setText("totalTop", totalDistance >= 1000 ? (totalDistance/1000).toFixed(2) + " km" : totalDistance.toFixed(0));
  setText("maxSpeed", maxSpeed.toFixed(2) + " km/h");
  setText("maxSpeedTop", maxSpeed.toFixed(2));
  setText("onlineTime", formatDuration(now - firstOnlineTime));
  setText("seq", seq);
  setText("time", new Date(lastFreshTime).toLocaleString("th-TH"));

  const googleURL = `https://www.google.com/maps?q=${lat},${lon}`;
  document.getElementById("googleMapsBtn").href = googleURL;
  setText("gmapsText", googleURL);

  marker.setPopupContent(
    `<b>🚚 รถขนส่ง</b><br>` +
    `Lat: ${lat.toFixed(7)}<br>` +
    `Lon: ${lon.toFixed(7)}<br>` +
    `Satellites: ${sat}<br>` +
    `Speed: ${displaySpeed.toFixed(2)} km/h<br>` +
    `Raw Speed: ${rawSpeed.toFixed(2)} km/h<br>` +
    `ESP Speed: ${espSpeed.toFixed(2)} km/h<br>` +
    `Distance drift: ${driftDistance.toFixed(1)} m<br>` +
    `Move threshold: ${moveThreshold.toFixed(1)} m<br>` +
    `Real Speed: ${realSpeed.toFixed(2)} km/h<br>` +
    `Total: ${formatDistance(totalDistance)}<br>` +
    `Max: ${maxSpeed.toFixed(2)} km/h<br>` +
    `Seq: ${seq}<br>` +
    `Status: ${document.getElementById("status").textContent}`
  );

  if(isFirstLoad){
    if(!viewingHistory) map.setView([lat,lon],17);
    marker.openPopup();
    isFirstLoad = false;
  }
}

async function loadGPS(){
  try{
    const res = await fetch(firebaseURL + "?t=" + Date.now(), {cache:"no-store"});
    const data = await res.json();
    processGPS(data);
  }catch(err){
    console.log(err);
    setStatus("offline");
  }
}

function startRealtime(){
  // ใช้ Firebase REST Streaming เพื่อรับข้อมูลทันทีเมื่อ ESP32 ส่งขึ้น Firebase
  try{
    const es = new EventSource(firebaseURL);
    es.addEventListener("put", (event) => {
      try{
        const msg = JSON.parse(event.data);
        if(msg && msg.data) processGPS(msg.data);
      }catch(e){ console.log(e); }
    });
    es.addEventListener("patch", (event) => {
      try{
        const msg = JSON.parse(event.data);
        if(msg && msg.data) processGPS(msg.data);
      }catch(e){ console.log(e); }
    });
    es.onerror = () => {
      // ถ้า Streaming มีปัญหา ให้กลับไปใช้ fetch ทุก 1 วิแทน
      console.log("Realtime stream error, fallback polling active");
    };
  }catch(err){
    console.log(err);
  }
}

// ตรวจ offline แยกจากการรับข้อมูล เพื่อไม่ให้รถจอดแล้วหลอกว่า offline
setInterval(() => {
  if(lastFreshTime && Date.now() - lastFreshTime > OFFLINE_LIMIT_MS){
    setStatus("offline");
  }
}, 1000);

// เริ่มระบบ: โหลดครั้งแรก + เปิด realtime + polling สำรองทุก 2 วิ
loadGPS();
startRealtime();
setInterval(loadGPS, 2000);


// V7 PWA install support
let deferredInstallPrompt = null;
window.addEventListener('beforeinstallprompt', (e) => {
  e.preventDefault();
  deferredInstallPrompt = e;
  const btn = document.getElementById('installBtn');
  if(btn) btn.style.display = 'block';
});
async function installApp(){
  if(deferredInstallPrompt){
    deferredInstallPrompt.prompt();
    await deferredInstallPrompt.userChoice;
    deferredInstallPrompt = null;
  }else{
    alert('ถ้าเป็น iPhone ให้กดปุ่ม Share แล้วเลือก Add to Home Screen\nถ้าเป็น Android ให้เปิดผ่าน Chrome และเลือก Install app/Add to Home screen');
  }
}
if('serviceWorker' in navigator){
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./service-worker.js').catch(console.log);
  });
}
</script>
</body>
</html>
